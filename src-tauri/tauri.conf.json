{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bloom",
  "version": "3.1.2",
  "identifier": "com.sehaz.bloom",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "bloom",
        "width": 1920,
        "height": 300,
        "x": 0,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "focus": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 380,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "alwaysOnTop": false,
        "visibleOnAllWorkspaces": false,
        "focus": true,
        "skipTaskbar": false,
        "shadow": true,
        "visible": false,
        "center": true
      },
      {
        "label": "volume-overlay",
        "title": "Volume",
        "url": "volume-overlay.html",
        "width": 200,
        "height": 400,
        "x": 0,
        "y": 48,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "focus": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "brightness-overlay",
        "title": "Brightness",
        "url": "brightness-overlay.html",
        "width": 200,
        "height": 400,
        "x": 1720,
        "y": 48,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "focus": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "dock",
        "title": "Bloom Dock",
        "url": "dock.html",
        "width": 1920,
        "height": 600,
        "x": 0,
        "y": 480,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "focus": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SehajveerSingh2005/bloom/releases/latest/download/latest.json"
